# Copy to .env for local runs. docker compose injects these for you; running
# the binary directly reads them from the environment. Config and secrets are
# supplied via environment only (AD-8) — never commit real values.

PORT=8080

# Consumed from Story 1.2 onward (pgx pool + goose migrations).
# Host port 5433 matches docker-compose (mapped to the container's 5432) so it
# doesn't collide with a native PostgreSQL on 5432.
DATABASE_URL=postgres://financas:financas@localhost:5433/financas?sslmode=disable

# Auth / sessions (Story 1.3):
SESSION_SECRET=change-me
# The single owner's login. OWNER_PASSWORD_HASH is an argon2id PHC hash, never a
# plaintext password — generate one with `make hashpw`.
OWNER_USERNAME=owner
OWNER_PASSWORD_HASH=
# Set true behind HTTPS (Azure); false for local http.
SECURE_COOKIES=false
